# ═══════════════════════════════════════════════════════════════════════════════
# TICKETIA — Variables de Entorno
# ═══════════════════════════════════════════════════════════════════════════════
# Instrucciones:
#   1. Copia este fichero: cp .env.example .env
#   2. Rellena los valores marcados con <REEMPLAZAR>
#   3. NUNCA subas .env a Git ni lo incluyas en el ZIP de entrega
# ═══════════════════════════════════════════════════════════════════════════════


# ── Flask ──────────────────────────────────────────────────────────────────────
# Clave secreta para firmar cookies de sesion. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<REEMPLAZAR_con_cadena_aleatoria_larga>


# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Necesario para: GPT-4o (agentes), Whisper (transcripcion audio), DALL-E (marketing)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=<REEMPLAZAR_sk-...>


# ── Twilio / WhatsApp ──────────────────────────────────────────────────────────
# Necesario para: recibir y enviar mensajes WhatsApp
# Obtener en: https://console.twilio.com
TWILIO_ACCOUNT_SID=<REEMPLAZAR_AC...>
TWILIO_AUTH_TOKEN=<REEMPLAZAR>
TWILIO_WHATSAPP_NUMBER=whatsapp:+<REEMPLAZAR_numero_twilio>

# URL publica donde Twilio puede hacer el webhook POST /whatsapp
# En desarrollo local usar ngrok: ngrok http 5000
# En Docker local: no es necesario para probar el dashboard web
PUBLIC_URL=https://<REEMPLAZAR_tu_dominio_o_ngrok>


# ── Base de datos ──────────────────────────────────────────────────────────────
# En Docker: esta variable la inyecta docker-compose.yml automaticamente.
# En local sin Docker: dejar en blanco para usar SQLite (desarrollo).
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ticketia_db


# ── Email (Flask-Mail) ─────────────────────────────────────────────────────────
# Necesario para: reset de contrasena, envio de documentos generados
# Con Gmail: usar una "App Password" (no la contrasena normal)
#   Activar en: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=<REEMPLAZAR_tu@gmail.com>
MAIL_PASSWORD=<REEMPLAZAR_app_password_16_caracteres>
MAIL_DEFAULT_SENDER=<REEMPLAZAR_tu@gmail.com>


# ── Runway ML (opcional) ───────────────────────────────────────────────────────
# Solo necesario para generacion de videos con el MarketingAgent
# Obtener en: https://app.runwayml.com/
RUNWAYML_API_SECRET=<REEMPLAZAR_o_dejar_vacio>


# ── MCP SSE (gestionado por Docker) ───────────────────────────────────────────
# En Docker: docker-compose.yml lo configura automaticamente.
# En local sin Docker: arrancar mcp_server_sse.py manualmente y descomentar:
# MCP_SSE_URL=http://localhost:8001/sse
# MCP_SSE_PORT=8001
